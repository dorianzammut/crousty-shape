# ──────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────
POSTGRES_USER=crousty
POSTGRES_PASSWORD=crousty_password

# ──────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ──────────────────────────────────────────────
# Firebase Admin SDK (optional — leave empty to disable)
# ──────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Escape newlines with \n when setting this in a single-line .env file
FIREBASE_PRIVATE_KEY=
